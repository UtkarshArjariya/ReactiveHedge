# Copy to .env.local. All public (NEXT_PUBLIC_) — no secrets in the frontend.
# Leave blank to run the dashboard in "demo mode" (animated, no live reads).

# RPCs
NEXT_PUBLIC_UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
NEXT_PUBLIC_REACTIVE_LASNA_RPC=https://lasna-rpc.rnk.dev/

# Deployed contract addresses (fill after running the deploy scripts)
NEXT_PUBLIC_HOOK_ADDRESS=
NEXT_PUBLIC_RSC_ADDRESS=
NEXT_PUBLIC_EXECUTOR_ADDRESS=

# The pool id (bytes32) the dashboard tracks; printed by CreatePoolAndAddLiquidity
NEXT_PUBLIC_POOL_ID=

# Demo control: swap router + pool currencies (printed by the pool/swap scripts)
NEXT_PUBLIC_SWAP_ROUTER=
NEXT_PUBLIC_POOL_CURRENCY0=
NEXT_PUBLIC_POOL_CURRENCY1=

# Reactscan base for the callback-tx link (FR-24)
NEXT_PUBLIC_REACTSCAN_URL=https://lasna.reactscan.net
