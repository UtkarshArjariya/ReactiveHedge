# Copy to .env.local. Leave everything blank to run in demo mode (animated loop).
#
# This is one Next.js app: the BROWSER never calls an RPC — the server route
# handlers (app/api/*) do all chain reads. So RPCs can be server-only/private.

# ── server-side RPCs (preferred; never sent to the browser) ──────────────────
RPC_UNICHAIN_SEPOLIA=https://sepolia.unichain.org
RPC_BASE_SEPOLIA=https://sepolia.base.org
RPC_REACTIVE=https://lasna-rpc.rnk.dev/

# ── deployed addresses (server reads use these; NEXT_PUBLIC_* also accepted) ──
HOOK_ADDRESS=
RSC_ADDRESS=
EXECUTOR_ADDRESS=
POOL_ID=

# ── client-exposed (needed only for the wallet "push external price" demo) ────
NEXT_PUBLIC_HOOK_ADDRESS=
NEXT_PUBLIC_POOL_ID=
NEXT_PUBLIC_SWAP_ROUTER=
NEXT_PUBLIC_POOL_CURRENCY0=
NEXT_PUBLIC_POOL_CURRENCY1=
NEXT_PUBLIC_REACTSCAN_URL=https://lasna.reactscan.net
