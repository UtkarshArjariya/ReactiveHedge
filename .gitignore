# ── Next.js (root app: frontend + backend) ──────────────────────────────────
/node_modules/
/.next/
/out/
/build/
next-env.d.ts
*.tsbuildinfo

# Secrets — never commit. Fresh dev wallet only, testnet only.
.env
.env.local
.env*.local

# ── Foundry (contracts/) ─────────────────────────────────────────────────────
contracts/out/
contracts/cache/
contracts/.forge-snapshots/
!contracts/broadcast
contracts/broadcast/*/31337/
contracts/broadcast/**/dry-run/

# ── Editors / OS ─────────────────────────────────────────────────────────────
# Track project-level editor config (excludes vendored submodule libs), ignore the rest.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.DS_Store
*.log
docs/
